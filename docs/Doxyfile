# Doxygen configuration for the Piclone firmware (C).
# Generates XML for Breathe; HTML output is left to Sphinx.

PROJECT_NAME           = "Piclone Firmware"
PROJECT_BRIEF          = "Pico-hosted ROM, clock, and Hardware API for the W65C02S"
OUTPUT_DIRECTORY       = _doxygen

# Sources: firmware only.
INPUT                  = ../piclone
FILE_PATTERNS          = *.c *.h
RECURSIVE              = YES

# Parse C correctly.
OPTIMIZE_OUTPUT_FOR_C  = YES
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = YES

# Breathe consumes XML; disable the rest.
GENERATE_XML           = YES
XML_OUTPUT             = xml
GENERATE_HTML          = NO
GENERATE_LATEX         = NO

# Quieter output and useful comment handling.
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES
