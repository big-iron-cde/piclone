# =============================================================================
# C / C++ build artifacts
# =============================================================================

# Object files
*.o
*.obj
*.elf

# Precompiled headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex
*.bin

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Dependency files
*.d

# =============================================================================
# CMake
# =============================================================================

CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json
CTestTestfile.cmake
_deps/

# Build directories (common names)
**/build/
**/build-*/
**/out/
**/out-*/
**/cmake-build-*/

# =============================================================================
# Raspberry Pi Pico SDK / Pico-specific
# =============================================================================

# Generated UF2 files are build artifacts (keep source, ignore output)
# Note: if you want to distribute pre-built UF2s, comment this out
*.uf2

# Pico SDK generated files
pico-sdk/
generated/
pioasm/
pioasm-install/
pico_flash_region.ld

# Disassembly / map files (large, regenerated)
*.dis
*.map

# =============================================================================
# Python (for host-side tooling like rom-builder/)
# =============================================================================

__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
venv/
env/
ENV/
.venv/

